{
  "name": "vibe-coding-platform-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "fluxio": "scripts/fluxio-cli.mjs"
  },
  "files": [
    "README.md",
    "docs/CLI_REFERENCE.md",
    "docs/FLUXIO_OPERATOR_TUTORIAL.md",
    "package.json",
    "scripts/fluxio-cli.mjs",
    "scripts/launch_fluxio.py",
    "scripts/run_web_backend.py",
    "scripts/verify_live_data_contract.py",
    "scripts/verify_parallel_dispatch_evidence.py",
    "scripts/verify_public_web_distribution.py",
    "scripts/verify_private_nas_web_deployment.py",
    "scripts/verify_public_launch_readiness.py",
    "scripts/public_launch_doctor.py",
    "scripts/record_github_release_publication.py",
    "scripts/verify_self_improvement_evidence.py",
    "scripts/advance_self_improvement_red_team_loop.py",
    "scripts/verify_launcher_package.py",
    "scripts/verify_authenticated_live_control.py",
    "scripts/verify_authenticated_live_agent.py",
    "scripts/verify_authenticated_phone_progress.py",
    "scripts/run_route_trust_sampling_missions.py",
    "scripts/review_route_trust_sampling_closeouts.py",
    "scripts/advance_route_trust_sampling_loop.py",
    "scripts/plan_mission_artifact_repairs.py",
    "scripts/plan_nas_storage_cleanup.py",
    "scripts/mind_tower_bridge.py",
    "scripts/render_mission_evidence_screenshots.py",
    "scripts/sync_nas_mission_detail_status.py",
    "scripts/sync_nas_system_audit.py",
    "scripts/verify_pwa_shell.py",
    "scripts/archive_release_proofs.py",
    "src",
    "web/dist",
    "web/index.html",
    "web/public",
    "web/src"
  ],
  "scripts": {
    "fluxio": "python scripts/launch_fluxio.py",
    "start": "python scripts/launch_fluxio.py",
    "frontend:dev": "vite --config vite.config.mjs",
    "frontend:build": "vite build --config vite.config.mjs",
    "web:backend": "python scripts/run_web_backend.py",
    "web:serve": "npm run frontend:build && python scripts/run_web_backend.py",
    "nas:setup": "python scripts/nas_setup.py",
    "verify:browser": "node scripts/control_route_smoke.mjs",
    "verify:fluxio-actions": "node scripts/verify_fluxio_action_contract.mjs",
    "verify:responsive": "python scripts/control_route_responsive_smoke.py",
    "verify:windows-ui": "python scripts/verify_windows_control_ui.py",
    "verify:workbench-program-bridge": "python scripts/verify_workbench_program_bridge.py",
    "verify:pwa": "python scripts/verify_pwa_shell.py",
    "verify:live-data": "python scripts/verify_live_data_contract.py --require-built-dist",
    "verify:authenticated-live": "python scripts/verify_authenticated_live_control.py",
    "verify:authenticated-live-agent": "python scripts/verify_authenticated_live_agent.py",
    "verify:authenticated-phone": "python scripts/verify_authenticated_phone_progress.py",
    "verify:live-detail-performance": "python scripts/verify_live_mission_detail_performance.py --write",
    "verify:parallel-dispatch": "python scripts/verify_parallel_dispatch_evidence.py --write",
    "verify:web-distribution": "python scripts/verify_public_web_distribution.py",
    "verify:private-nas-web": "python scripts/verify_private_nas_web_deployment.py --write",
    "verify:public-launch": "python scripts/verify_public_launch_readiness.py --write",
    "doctor:public-launch": "python scripts/public_launch_doctor.py --write",
    "plan:github-release-publication": "python scripts/record_github_release_publication.py --plan --write-plan",
    "record:github-release-publication": "python scripts/record_github_release_publication.py",
    "verify:self-improvement": "python scripts/verify_self_improvement_evidence.py --write",
    "sample:self-improvement-red-team": "python scripts/verify_self_improvement_evidence.py --record-red-team-sample --write",
    "advance:self-improvement-red-team": "python scripts/advance_self_improvement_red_team_loop.py --write --max-steps 1 --record-cadence-receipt",
    "sample:route-trust-live": "python scripts/run_route_trust_sampling_missions.py --write",
    "sample:route-trust-closeout": "python scripts/review_route_trust_sampling_closeouts.py --write",
    "sample:route-trust-loop": "python scripts/advance_route_trust_sampling_loop.py --write --resume-stale-waiting",
    "repair:mission-artifacts": "python scripts/plan_mission_artifact_repairs.py --write",
    "render:mission-evidence": "python scripts/render_mission_evidence_screenshots.py",
    "plan:nas-storage-cleanup": "python scripts/plan_nas_storage_cleanup.py --write --write-pressure",
    "sync:nas-mission-detail-status": "python scripts/sync_nas_mission_detail_status.py --write",
    "benchmark:t3-code": "python scripts/refresh_t3_code_benchmark.py --write",
    "sync:nas-audit": "python scripts/sync_nas_system_audit.py --push-local-evidence-files --publish-remote-snapshot",
    "verify:launcher-package": "python scripts/verify_launcher_package.py --write",
    "verify:beginner-launch": "python scripts/control_route_responsive_smoke.py --assert-launch-interactions --expect \"Recommended route\" --expect \"Quick start\"",
    "verify:long-history": "python scripts/control_route_responsive_smoke.py --long-history-fixture --expect Builder --expect \"Long-History Proof Load\" --expect \"Side-by-side proof diff\"",
    "verify:release-artifacts": "python scripts/archive_release_proofs.py --require-long-history --require-proof-digest",
    "verify:release-candidate": "python scripts/archive_release_proofs.py --require-long-history --require-proof-digest --require-public-web-deployment",
    "verify:pr-stack": "python scripts/pr_stack_health.py --max-chain 5",
    "proof:pr-stack": "python scripts/pr_stack_health.py --max-chain 5 --output artifacts/pr-stack-health-local/pr-stack-health.json",
    "verify:control": "python scripts/verify_control_workspace.py",
    "verify:desktop": "python -m pytest tests -q && npm run frontend:build && npm run tauri build -- --debug",
    "dev": "tauri dev",
    "dev:live": "powershell -NoProfile -Command \"Get-Process vibe-coding-platform,cargo -ErrorAction SilentlyContinue | Stop-Process -Force\"; tauri dev",
    "build": "tauri build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.8.0",
    "class-variance-authority": "^0.7.1",
    "effect": "^4.0.0-beta.43",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.0",
    "@vitejs/plugin-react": "^5.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.1.3"
  }
}
