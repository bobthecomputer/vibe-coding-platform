{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/worker-f-jbheaven-safe-transcript.schema.json",
  "title": "Worker F JBH-EAVEN Safe Red-Team Transcript",
  "type": "object",
  "required": [
    "scenario_id",
    "run_id",
    "mode",
    "selected_skill",
    "runtime_route",
    "loop_trace",
    "authorization_labels",
    "category_mapping",
    "target_boundary",
    "probe_results",
    "proof_summary",
    "artifact_paths",
    "browser_proof"
  ],
  "additionalProperties": false,
  "properties": {
    "scenario_id": {
      "const": "worker-f-jbheaven-safe-scenario-20260621"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "dry-run-artifact",
        "supervised-live-run"
      ]
    },
    "selected_skill": {
      "const": "jbheaven-hermes-project"
    },
    "runtime_route": {
      "type": "object",
      "required": [
        "runtime",
        "provider",
        "model",
        "route_reason",
        "live_model_calls"
      ],
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "const": "hermes"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "route_reason": {
          "type": "string",
          "minLength": 1
        },
        "live_model_calls": {
          "const": false
        }
      }
    },
    "loop_trace": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "step",
          "status",
          "proof_artifact"
        ],
        "additionalProperties": false,
        "properties": {
          "step": {
            "enum": [
              "plan",
              "execute",
              "verify",
              "repair"
            ]
          },
          "status": {
            "enum": [
              "complete",
              "ready",
              "blocked"
            ]
          },
          "proof_artifact": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "authorization_labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "category_mapping": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "family",
          "owasp_risk",
          "nist_measure"
        ],
        "additionalProperties": false,
        "properties": {
          "family": {
            "type": "string",
            "minLength": 1
          },
          "owasp_risk": {
            "type": "string",
            "minLength": 1
          },
          "nist_measure": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "target_boundary": {
      "type": "object",
      "required": [
        "fictional_only",
        "real_targets_used",
        "network_activity"
      ],
      "additionalProperties": false,
      "properties": {
        "fictional_only": {
          "type": "boolean"
        },
        "real_targets_used": {
          "const": false
        },
        "network_activity": {
          "const": false
        }
      }
    },
    "probe_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
          "required": [
            "probe_id",
            "family",
            "authorization_label",
            "owasp_risk",
            "nist_measure",
            "runtime",
            "provider",
            "model",
            "selected_skill",
            "route_reason",
            "loop_step",
            "visible_prompt",
            "visible_response",
            "safety_rationale",
            "hidden_reasoning_omitted",
            "outcome",
            "score",
            "reviewer_notes",
            "artifact_path",
            "transcript_artifact_path"
        ],
        "additionalProperties": false,
        "properties": {
          "probe_id": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "authorization_label": {
            "type": "string"
          },
          "owasp_risk": {
            "type": "string",
            "minLength": 1
          },
          "nist_measure": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "const": "hermes"
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "selected_skill": {
            "const": "jbheaven-hermes-project"
          },
          "route_reason": {
            "type": "string",
            "minLength": 1
          },
          "loop_step": {
            "enum": [
              "execute",
              "verify",
              "repair"
            ]
          },
          "visible_prompt": {
            "type": "string"
          },
          "visible_response": {
            "type": "string"
          },
          "safety_rationale": {
            "type": "string",
            "minLength": 1
          },
          "hidden_reasoning_omitted": {
            "const": true
          },
          "outcome": {
            "enum": [
              "PASS",
              "REVIEW",
              "FAIL"
            ]
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "reviewer_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "transcript_artifact_path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "proof_summary": {
      "type": "object",
      "required": [
        "live_model_calls",
        "harmful_instructions_included",
        "overall_outcome",
        "promotion_blocked",
        "promotion_block_reason"
      ],
      "additionalProperties": false,
      "properties": {
        "live_model_calls": {
          "type": "boolean"
        },
        "harmful_instructions_included": {
          "const": false
        },
        "overall_outcome": {
          "enum": [
            "PASS",
            "REVIEW",
            "FAIL"
          ]
        },
        "promotion_blocked": {
          "type": "boolean"
        },
        "promotion_block_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact_paths": {
      "type": "object",
      "required": [
        "scenario",
        "probes",
        "rubric",
        "transcript",
        "index",
        "browser_proof",
        "desktop_screenshot",
        "mobile_screenshot"
      ],
      "additionalProperties": false,
      "properties": {
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "probes": {
          "type": "string",
          "minLength": 1
        },
        "rubric": {
          "type": "string",
          "minLength": 1
        },
        "transcript": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "string",
          "minLength": 1
        },
        "browser_proof": {
          "type": "string",
          "minLength": 1
        },
        "desktop_screenshot": {
          "type": "string",
          "minLength": 1
        },
        "mobile_screenshot": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "browser_proof": {
      "type": "object",
      "required": [
        "status",
        "check_path",
        "desktop_screenshot",
        "mobile_screenshot"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "check_path": {
          "type": "string",
          "minLength": 1
        },
        "desktop_screenshot": {
          "type": "string",
          "minLength": 1
        },
        "mobile_screenshot": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
