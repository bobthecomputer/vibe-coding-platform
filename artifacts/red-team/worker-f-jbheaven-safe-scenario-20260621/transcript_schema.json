{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/worker-f-jbheaven-safe-transcript.schema.json",
  "title": "Worker F JBH-EAVEN Safe Red-Team Transcript",
  "type": "object",
  "required": [
    "scenario_id",
    "run_id",
    "mode",
    "authorization_labels",
    "target_boundary",
    "probe_results",
    "proof_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "scenario_id": {
      "const": "worker-f-jbheaven-safe-scenario-20260621"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "dry-run-artifact",
        "supervised-live-run"
      ]
    },
    "authorization_labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "target_boundary": {
      "type": "object",
      "required": [
        "fictional_only",
        "real_targets_used",
        "network_activity"
      ],
      "additionalProperties": false,
      "properties": {
        "fictional_only": {
          "type": "boolean"
        },
        "real_targets_used": {
          "const": false
        },
        "network_activity": {
          "const": false
        }
      }
    },
    "probe_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "probe_id",
          "family",
          "authorization_label",
          "visible_prompt",
          "visible_response",
          "safety_rationale",
          "hidden_reasoning_omitted",
          "outcome",
          "score",
          "reviewer_notes"
        ],
        "additionalProperties": false,
        "properties": {
          "probe_id": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "authorization_label": {
            "type": "string"
          },
          "visible_prompt": {
            "type": "string"
          },
          "visible_response": {
            "type": "string"
          },
          "safety_rationale": {
            "type": "string",
            "minLength": 1
          },
          "hidden_reasoning_omitted": {
            "const": true
          },
          "outcome": {
            "enum": [
              "PASS",
              "REVIEW",
              "FAIL"
            ]
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "reviewer_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "proof_summary": {
      "type": "object",
      "required": [
        "live_model_calls",
        "harmful_instructions_included",
        "overall_outcome"
      ],
      "additionalProperties": false,
      "properties": {
        "live_model_calls": {
          "type": "boolean"
        },
        "harmful_instructions_included": {
          "const": false
        },
        "overall_outcome": {
          "enum": [
            "PASS",
            "REVIEW",
            "FAIL"
          ]
        }
      }
    }
  }
}
